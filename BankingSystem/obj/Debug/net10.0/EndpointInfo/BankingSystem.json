  "components": {
    "schemas": {
      "CreateTransactionRequest": {
        "required": [
          "accountNumber",
          "amount",
          "birthDate",
          "fullNameEnglish",
          "fullNameHebrew",
          "idNumber",
          "type"
        ],
        "type": "object",
        "properties": {
          "fullNameHebrew": {
            "maxLength": 20,
            "minLength": 1,
            "pattern": "^[\\u0590-\\u05FF\\s'-]+$",
            "type": "string"
          },
          "fullNameEnglish": {
            "maxLength": 15,
            "minLength": 1,
            "pattern": "^[a-zA-Z\\s'-]+$",
            "type": "string"
          },
          "birthDate": {
            "type": "string",
            "format": "date-time"
          },
          "idNumber": {
            "minLength": 1,
            "pattern": "^\\d{9}$",
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/TransactionType"
          },
          "amount": {
            "maximum": 9999999999,
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          },
          "accountNumber": {
            "minLength": 1,
            "pattern": "^\\d{1,10}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ObjectBaseResponse": {
        "required": [
          "code",
          "message",
          "success"
        ],
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string",
            "nullable": true
          },
          "code": {
            "$ref": "#/components/schemas/ResponseCode"
          },
          "data": {
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ResponseCode": {
        "enum": [
          "Success",
          "Created",
          "NoContent",
          "BadRequest",
          "Unauthorized",
          "Forbidden",
          "NotFound",
          "Conflict",
          "InternalServerError",
          "ServiceUnavailable"
        ],
        "type": "string"
      },
      "Transaction": {
        "required": [
          "accountNumber",
          "amount",
          "birthDate",
          "fullNameEnglish",
          "fullNameHebrew",
          "idNumber",
          "status",
          "type"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "fullNameHebrew": {
            "maxLength": 20,
            "minLength": 1,
            "type": "string"
          },
          "fullNameEnglish": {
            "maxLength": 15,
            "minLength": 1,
            "type": "string"
          },
          "birthDate": {
            "type": "string",
            "format": "date-time"
          },
          "idNumber": {
            "maxLength": 9,
            "minLength": 9,
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/TransactionType"
          },
          "amount": {
            "maximum": 9999999999,
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          },
          "accountNumber": {
            "maxLength": 10,
            "minLength": 1,
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/TransactionStatus"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "isDeleted": {
            "type": "boolean"
          },
          "lastAction": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "TransactionBaseResponse": {
        "required": [
          "code",
          "message",
          "success"
        ],
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string",
            "nullable": true
          },
          "code": {
            "$ref": "#/components/schemas/ResponseCode"
          },
          "data": {
            "$ref": "#/components/schemas/Transaction"
          }
        },
        "additionalProperties": false
      },
      "TransactionListBaseResponse": {
        "required": [
          "code",
          "message",
          "success"
        ],
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string",
            "nullable": true
          },
          "code": {
            "$ref": "#/components/schemas/ResponseCode"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Transaction"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "TransactionStatus": {
        "enum": [
          "Success",
          "Failed",
          "Cancelled"
        ],
        "type": "string"
      },
      "TransactionType": {
        "enum": [
          "Deposit",
          "Withdrawal"
        ],
        "type": "string"
      }
    }
  }
}